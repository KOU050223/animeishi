{
  "name": "@animeishi/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest run && vitest run --config vitest.eslint.config.ts",
    "test:watch": "vitest",
    "test:eslint-rules": "vitest run --config vitest.eslint.config.ts",
    "lint": "eslint src __tests__",
    "format": "prettier --write src __tests__",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply animeishi-db --local",
    "db:seed:local": "wrangler d1 execute animeishi-db --local --file=./seeds/seed.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@animeishi/schema": "workspace:*",
    "@clerk/backend": "^3.2.12",
    "@hono/clerk-auth": "^3.1.1",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20260416.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^10.2.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.12.0"
  }
}
